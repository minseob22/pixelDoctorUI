# ================================================================
# Database (Neon PostgreSQL)
# Neon 대시보드 → Connection Details → Prisma 선택 후 복사
# ================================================================
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/xray_ai_db?sslmode=require"

# ================================================================
# NextAuth.js
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` 로 생성
# ================================================================
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ================================================================
# OpenAI (ChatGPT API)
# ================================================================
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# ================================================================
# Google AI (Gemini — LangChain 폴백 모델)
# ================================================================
GOOGLE_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.0-flash-preview"

# ================================================================
# 자체 분석 모델 엔드포인트
# ================================================================
XRAY_MODEL_API_URL="http://your-xray-model/api/analyze"
XRAY_MODEL_API_KEY=""

CT_MODEL_API_URL="http://your-ct-model/api/analyze"
CT_MODEL_API_KEY=""

# ================================================================
# 파일 스토리지
# ================================================================
STORAGE_TYPE="local"
LOCAL_UPLOAD_DIR="./uploads"

AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-northeast-2"
AWS_S3_BUCKET=""

# ================================================================
# 앱 설정
# ================================================================
NEXT_PUBLIC_APP_NAME="X-ray AI Assistant"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
